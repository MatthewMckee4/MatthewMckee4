{
    "name": "matthew-mckee",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "type-check": "tsc --noEmit",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "prepare": "husky",
        "type-check-staged": "tsc --noEmit --skipLibCheck"
    },
    "dependencies": {
        "next": "14.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@types/node": "^20.11.19",
        "@types/react": "^18.2.57",
        "@types/react-dom": "^18.2.19",
        "autoprefixer": "10.4.14",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.1",
        "postcss": "8.4.31",
        "tailwindcss": "3.3.0",
        "tsc-files": "^1.1.4",
        "typescript": "^5.3.3"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,md}": [
            "biome check --write --no-errors-on-unmatched"
        ],
        "*.{ts,tsx}": [
            "bash -c 'yarn type-check-staged'"
        ]
    }
}
